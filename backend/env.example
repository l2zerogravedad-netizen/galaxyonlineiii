# DESTOCK SPACE Backend - Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=destock_space_common
DB_USER=destock_user
DB_PASSWORD=your_secure_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_here
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_key_here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:8080

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# WebSocket Configuration
WS_CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:8080
WS_PING_TIMEOUT=60000
WS_PING_INTERVAL=25000

# Game Configuration
GAME_TICK_RATE=1000
COMBAT_TURN_TIME_LIMIT=30
MAX_PARTICIPANTS_PER_COMBAT=10
MARKETPLACE_FEE_RATE=0.05
TRANSACTION_FEE_RATE=0.02

# Economic Configuration
BASE_PRODUCTION_RATE=1.0
RESOURCE_STORAGE_MULTIPLIER=100
MAX_MARKETPLACE_LISTINGS=50
MIN_LISTING_PRICE=10
MAX_TRANSACTION_AMOUNT=1000000

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here
API_KEY_HEADER=X-API-Key
API_KEY=your_api_key_here

# External Services
EMAIL_SERVICE_HOST=smtp.gmail.com
EMAIL_SERVICE_PORT=587
EMAIL_SERVICE_USER=your_email@gmail.com
EMAIL_SERVICE_PASS=your_email_password

# Monitoring and Analytics
SENTRY_DSN=your_sentry_dsn_here
ANALYTICS_ENABLED=false
METRICS_ENABLED=true

# Development Configuration
DEBUG=destock-space:*
SWAGGER_ENABLED=true
MOCK_EXTERNAL_APIS=false
